# Copy this file to .env for local builds. NEVER commit .env.
# All VITE_* vars are baked into the bundle AT BUILD TIME (this is a static SPA),
# so in production they're set in the Vercel project (Production + Preview), not
# in a deployed file.

# ── Backend location (REQUIRED) ──────────────────────────────────────────────
# The ONLY place the backend URL is configured. The app sends every request
# directly to this origin — there is no fallback, proxy, or rewrite. Use the
# bare origin: no trailing slash and no "/api" suffix (the app appends "/api").
#   - local dev:  http://localhost:3001   (or your Railway dev URL)
#   - production: https://api.jobjen.com   (set in the Vercel dashboard)
# Requests are cross-origin, so the backend's FRONTEND_ORIGIN allow-list must
# include this SPA's origin (CORS).
VITE_API_BASE_URL=https://api.jobjen.com

# ── Security ─────────────────────────────────────────────────────────────────
# "true" enables DevTools detection on the /assessment route (recommended in
# production). "false" (or unset) skips the guard — handy for local debugging.
VITE_ENABLE_DEVTOOLS_GUARD=true

# ── Perimeter HTTP Basic Auth ────────────────────────────────────────────────
# The prod backend wraps the whole API in Basic Auth; without these the app gets
# a wall of 401s at crypto bootstrap. In dev the middleware is a no-op, so leave
# them blank locally. NOT a secret (it's baked into the bundle) — it's a
# perimeter; the real authn is the single-use technical JWT from the URL.
#
# Either the pre-encoded form (preferred):
VITE_API_BASIC_AUTH=
# …or the three parts (base64-encoded at load as user:pass:marker):
VITE_API_BASIC_AUTH_USER=
VITE_API_BASIC_AUTH_PASS=
VITE_API_BASIC_AUTH_MARKER=
