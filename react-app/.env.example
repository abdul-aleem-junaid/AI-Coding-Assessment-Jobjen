# ── API Configuration ────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Base URL for all Jobjen backend API calls (no trailing slash)
VITE_API_BASE_URL=https://api.jobjen.com/v1

# Candidate token passed as a query-param when the recruiter sends the
# assessment link, e.g. /assessment?token=<JWT>
# Leave empty — the app reads it automatically from the URL.
VITE_CANDIDATE_TOKEN=

# Optional: hard-code a token for local dev so you don't need URL params
VITE_DEV_TOKEN=

# ── Security ─────────────────────────────────────────────────────────────────
# Set to "true" to enable DevTools detection on the /assessment route.
# When "false" (or missing), the guard is completely skipped — useful during
# local development so you can inspect the app without being redirected.
VITE_ENABLE_DEVTOOLS_GUARD=true
